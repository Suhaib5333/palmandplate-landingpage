---
import { Image } from "astro:assets";
import heroImg from "@/assets/images/events/vol01-group.jpg";
---

<section id="hero" class="relative min-h-screen flex items-end overflow-hidden">
  <!-- Background image — optimized by Astro -->
  <div class="absolute inset-0">
    <Image
      src={heroImg}
      alt="Palm & Plate community at a dining event"
      width={1920}
      height={1080}
      quality={70}
      format="webp"
      class="w-full h-full object-cover object-top parallax"
      data-speed="0.15"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/60 to-charcoal/20"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/40 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-12 pb-20 md:pb-28 pt-40">
    <div class="max-w-3xl">
      <div class="hero-fade inline-flex items-center gap-3 mb-8">
        <div class="w-8 h-[1px] bg-saffron"></div>
        <p class="text-saffron font-body font-medium tracking-[0.3em] uppercase text-xs">
          Bahrain's First Food Club
        </p>
      </div>

      <h1 class="hero-fade hero-delay-1 text-display font-heading text-cream mb-6">
        Where Every Meal<br />
        Tells a <span class="text-saffron">Story</span>
      </h1>

      <p class="hero-fade hero-delay-2 text-lg md:text-xl text-cream/70 font-body font-light max-w-xl mb-10 leading-relaxed">
        Curated dining experiences that bring together Bahrain's most passionate food lovers.
        One table, one night, one unforgettable memory.
      </p>

      <div class="hero-fade hero-delay-3 flex flex-col sm:flex-row gap-4">
        <a href="#waitlist" class="btn-primary">Join the Waitlist</a>
        <a href="#about" class="btn-secondary">Discover More</a>
      </div>
    </div>

    <div class="hidden md:flex absolute bottom-10 right-12 flex-col items-center gap-3">
      <span class="text-cream/40 font-body text-xs tracking-widest uppercase rotate-90 origin-center translate-x-4 -translate-y-8">Scroll</span>
      <div class="w-[1px] h-16 bg-gradient-to-b from-cream/0 via-cream/40 to-cream/0 scroll-line"></div>
    </div>
  </div>
</section>

<!-- Marquee strip -->
<div class="bg-clay py-3 overflow-hidden">
  <div class="animate-marquee whitespace-nowrap flex">
    {Array(10).fill(null).map(() => (
      <span class="mx-8 text-cream/80 font-body text-sm tracking-widest uppercase flex items-center gap-8">
        <span>Exclusive Events</span>
        <span class="text-saffron text-lg">✦</span>
        <span>Curated Menus</span>
        <span class="text-saffron text-lg">✦</span>
        <span>Community</span>
        <span class="text-saffron text-lg">✦</span>
        <span>Bahrain</span>
        <span class="text-saffron text-lg">✦</span>
      </span>
    ))}
  </div>
</div>

<style>
  @keyframes hero-enter {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-fade { animation: hero-enter 1s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .hero-delay-1 { animation-delay: 0.2s; }
  .hero-delay-2 { animation-delay: 0.4s; }
  .hero-delay-3 { animation-delay: 0.6s; }
  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 0.6; }
  }
  .scroll-line { animation: scroll-pulse 2s ease-in-out infinite; }
</style>
