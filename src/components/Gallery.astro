---
// Gallery section — photo highlights from past events
// TODO: Replace placeholders with actual images
const images = [
  { alt: "Dining event at Palm & Plate", span: "col-span-2 row-span-2" },
  { alt: "Chef preparing dish", span: "" },
  { alt: "Members enjoying dinner", span: "" },
  { alt: "Beautifully plated food", span: "" },
  { alt: "Food crawl in Muharraq", span: "" },
  { alt: "Community gathering", span: "col-span-2" },
];
---

<section id="gallery" class="section-padding bg-white">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <p
        class="text-palm-600 font-medium tracking-widest uppercase text-sm mb-4"
      >
        Highlights
      </p>
      <h2 class="section-heading mb-6">Moments We've Shared</h2>
      <p class="section-subheading mx-auto">
        Every event tells a story. Here are some of our favourite moments from
        past gatherings.
      </p>
    </div>

    <!-- Image grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      {
        images.map((image, i) => (
          <div
            class={`relative overflow-hidden rounded-xl bg-gradient-to-br from-plate-100 to-palm-100 group cursor-pointer ${image.span} ${
              image.span.includes("row-span-2")
                ? "min-h-[300px] md:min-h-[400px]"
                : "min-h-[150px] md:min-h-[200px]"
            }`}
          >
            {/* TODO: Replace with actual images */}
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-4xl md:text-5xl opacity-20">📸</span>
            </div>
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-all duration-300" />
          </div>
        ))
      }
    </div>

    <!-- Instagram CTA -->
    <div class="text-center mt-12">
      <p class="text-charcoal/60 mb-4">Follow our journey on social media</p>
      <a
        href="#"
        class="inline-flex items-center gap-2 text-palm-600 font-medium hover:text-palm-700 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
          ></path>
        </svg>
        @palmandplate
      </a>
    </div>
  </div>
</section>
