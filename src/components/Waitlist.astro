---
import { Image } from "astro:assets";
import groupImg from "@/assets/images/events/vol01-group.jpg";
import food2Img from "@/assets/images/events/vol05/vol05-soup.jpg";
import momentImg from "@/assets/images/events/vol01-moment.jpg";
import logoIconGold from "@/assets/images/brand/logo-icon-gold.png";
---

<section id="waitlist" class="relative overflow-hidden bg-charcoal">

  <!-- Top: Full-width photo mosaic strip -->
  <div class="grid grid-cols-3 h-[180px] md:h-[260px] gap-[2px]">
    <div class="img-zoom overflow-hidden">
      <Image
        src={groupImg}
        alt="Palm & Plate members at dinner"
        width={640}
        height={280}
        quality={70}
        format="webp"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="img-zoom overflow-hidden">
      <Image
        src={food2Img}
        alt="Beautifully plated dish"
        width={640}
        height={280}
        quality={70}
        format="webp"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="img-zoom overflow-hidden">
      <Image
        src={momentImg}
        alt="Members connecting over food"
        width={640}
        height={280}
        quality={70}
        format="webp"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  </div>

  <!-- Main content area -->
  <div class="relative px-6 md:px-12 lg:px-24 py-20 md:py-28">
    <!-- Background decorative elements -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
      <div class="absolute -top-32 -right-32 w-96 h-96 bg-saffron/5 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-clay/5 rounded-full blur-3xl"></div>
      <Image
        src={logoIconGold}
        alt=""
        width={400}
        height={400}
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] opacity-[0.03]"
        loading="lazy"
      />
    </div>

    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <!-- Badge -->
      <div class="reveal flex items-center justify-center gap-3 mb-8">
        <div class="w-12 h-[1px] bg-saffron/40"></div>
        <p class="text-saffron font-body font-medium tracking-[0.3em] uppercase text-xs">Limited Spots</p>
        <div class="w-12 h-[1px] bg-saffron/40"></div>
      </div>

      <!-- Heading -->
      <h2 class="reveal font-heading text-4xl md:text-5xl lg:text-6xl text-cream mb-6 leading-tight">
        Ready to Pull Up<br />a Chair?
      </h2>

      <!-- Description -->
      <p class="reveal font-body font-light text-cream/50 text-lg leading-relaxed max-w-xl mx-auto mb-14">
        We keep our community intimate — spots are limited. Join the waitlist
        and we'll reach out when there's a seat at the table for you.
      </p>

      <!-- Benefits -->
      <div class="stagger-children grid grid-cols-1 md:grid-cols-3 gap-8 mb-14">
        <div class="flex flex-col items-center gap-3">
          <div class="w-12 h-12 rounded-full border border-saffron/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <span class="text-cream/60 font-body text-sm">Exclusive events<br />every month</span>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-12 h-12 rounded-full border border-saffron/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <span class="text-cream/60 font-body text-sm">First access to<br />new volumes</span>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-12 h-12 rounded-full border border-saffron/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <span class="text-cream/60 font-body text-sm">A community of<br />food lovers</span>
        </div>
      </div>

      <!-- CTA -->
      <div class="reveal">
        <a
          href="https://app.palmnplate.com"
          class="inline-flex items-center justify-center px-12 py-5 bg-saffron text-charcoal font-body font-bold tracking-wider uppercase text-sm hover:bg-saffron-light transition-all duration-500 group"
        >
          Join the Waitlist
          <svg class="w-4 h-4 ml-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <p class="reveal text-cream/30 font-body text-sm mt-8">
        Already a member?
        <a href="https://app.palmnplate.com/login" class="text-saffron hover:text-saffron-light transition-colors duration-300 underline underline-offset-4 decoration-saffron/30 hover:decoration-saffron">Log in</a>
      </p>

      <p class="reveal text-cream/20 font-body text-xs mt-4">
        No commitment. We'll be in touch.
      </p>
    </div>
  </div>

  <!-- Bottom accent -->
  <div class="w-full h-[2px] bg-gradient-to-r from-transparent via-saffron/30 to-transparent"></div>
</section>
