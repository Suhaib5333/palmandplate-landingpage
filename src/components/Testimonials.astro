---
const testimonials = [
  {
    quote: "Great networking!! Met amazing people and had great bites. 10/10 group and really appreciate the attention to detail!!",
    name: "Jimmy",
  },
  {
    quote: "The experience exceeded what was paid by far.",
    name: "Jonathan",
  },
  {
    quote: "A really great experience so worth it. I am excited to try again in the future!",
    name: "Falah",
  },
  {
    quote: "11/10 no words needed.",
    name: "Ahmed",
  },
];

// Prepend last item + original + append first item for seamless looping
const looped = [testimonials[testimonials.length - 1], ...testimonials, testimonials[0]];
---

<section class="relative overflow-hidden bg-cream-light py-24 md:py-32">
  <!-- Subtle background accents -->
  <div class="absolute top-0 left-0 w-full h-full pointer-events-none">
    <div class="absolute -top-40 -left-40 w-[500px] h-[500px] bg-saffron/[0.04] rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -right-40 w-[500px] h-[500px] bg-clay/[0.04] rounded-full blur-3xl"></div>
  </div>

  <!-- Top accent line -->
  <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-charcoal/10 to-transparent"></div>

  <!-- Header -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 mb-16 md:mb-20">
    <div class="reveal flex items-center gap-3 mb-6 justify-center">
      <div class="w-12 h-[1px] bg-clay/40"></div>
      <p class="text-clay font-body font-medium tracking-[0.3em] uppercase text-xs">What They Say</p>
      <div class="w-12 h-[1px] bg-clay/40"></div>
    </div>
    <h2 class="reveal section-heading text-charcoal text-center">
      Straight From<br />the Table
    </h2>
  </div>

  <!-- Scrolling testimonials track -->
  <div class="relative z-10">
    <!-- Gradient fade edges -->
    <div class="absolute left-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-r from-cream-light to-transparent z-20 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-l from-cream-light to-transparent z-20 pointer-events-none"></div>

    <!-- Scrolling track -->
    <div class="testimonial-track flex gap-6 md:gap-8" id="testimonial-track">
      {looped.map((t, i) => (
        <div class="testimonial-card flex-shrink-0 w-[85vw] md:w-[560px] lg:w-[640px] relative group">
          <div class="h-full border border-charcoal/[0.08] bg-white/60 p-8 md:p-12 transition-all duration-700 hover:border-clay/20 hover:bg-white/80">
            <!-- Large quote mark -->
            <div class="mb-6 md:mb-8">
              <svg class="w-10 h-10 md:w-14 md:h-14 text-clay/20 group-hover:text-clay/40 transition-colors duration-700" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
              </svg>
            </div>

            <!-- Quote text -->
            <blockquote class="font-heading text-charcoal text-2xl md:text-3xl lg:text-4xl leading-[1.3] mb-8 md:mb-10" style="line-height: 1.3 !important;">
              {t.quote}
            </blockquote>

            <!-- Author -->
            <div class="flex items-center gap-4">
              <div class="w-10 h-[1px] bg-clay/40"></div>
              <span class="font-body font-medium text-clay tracking-widest uppercase text-sm">
                {t.name}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Navigation dots -->
  <div class="relative z-10 flex justify-center gap-3 mt-12 md:mt-16" id="testimonial-dots">
    {testimonials.map((_, i) => (
      <button
        class={`testimonial-dot w-2 h-2 rounded-full transition-all duration-500 ${i === 0 ? "bg-clay w-8" : "bg-charcoal/20 hover:bg-charcoal/40"}`}
        data-index={i}
        aria-label={`Go to testimonial ${i + 1}`}
      />
    ))}
  </div>
</section>

<script>
  const track = document.getElementById("testimonial-track") as HTMLElement;
  const dots = document.querySelectorAll(".testimonial-dot");
  const cards = document.querySelectorAll(".testimonial-card");
  const totalOriginal = dots.length; // 4 real testimonials
  // Layout: [clone-last, 0, 1, 2, 3, clone-first] — 6 cards total
  // "index 0" in the real set = card index 1 in the DOM

  if (!track || totalOriginal === 0) throw new Error("Testimonials not found");

  let currentIndex = 0; // refers to the real testimonial index (0-3)
  let isAnimating = false;
  let autoplayTimer: ReturnType<typeof setInterval>;
  let isPaused = false;

  function getCardWidth(): number {
    const card = cards[0] as HTMLElement;
    const gap = window.innerWidth >= 768 ? 32 : 24;
    return card.offsetWidth + gap;
  }

  function getTrackPadding(): number {
    const style = window.getComputedStyle(track);
    return parseFloat(style.paddingLeft) || 0;
  }

  function updateDots(index: number) {
    const realIndex = ((index % totalOriginal) + totalOriginal) % totalOriginal;
    dots.forEach((dot, i) => {
      if (i === realIndex) {
        dot.classList.add("bg-clay", "w-8");
        dot.classList.remove("bg-charcoal/20", "hover:bg-charcoal/40");
        (dot as HTMLElement).style.width = "2rem";
      } else {
        dot.classList.remove("bg-clay", "w-8");
        dot.classList.add("bg-charcoal/20", "hover:bg-charcoal/40");
        (dot as HTMLElement).style.width = "";
      }
    });
  }

  // domIndex = currentIndex + 1 (because of prepended clone)
  function scrollToDomIndex(domIndex: number, smooth = true) {
    if (isAnimating) return;
    isAnimating = true;

    const cardWidth = getCardWidth();
    const offset = domIndex * cardWidth;

    track.style.transition = smooth ? "transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)" : "none";
    track.style.transform = `translateX(-${offset}px)`;

    const realIndex = domIndex - 1;
    updateDots(realIndex);

    setTimeout(() => {
      // If scrolled to the clone-first (domIndex = totalOriginal + 1), snap to real first (domIndex 1)
      if (domIndex >= totalOriginal + 1) {
        currentIndex = 0;
        track.style.transition = "none";
        track.style.transform = `translateX(-${1 * cardWidth}px)`;
      }
      // If scrolled to clone-last (domIndex = 0), snap to real last (domIndex = totalOriginal)
      else if (domIndex <= 0) {
        currentIndex = totalOriginal - 1;
        track.style.transition = "none";
        track.style.transform = `translateX(-${totalOriginal * cardWidth}px)`;
      }
      else {
        currentIndex = domIndex - 1;
      }
      isAnimating = false;
    }, smooth ? 850 : 50);
  }

  function nextSlide() {
    const domIndex = currentIndex + 1; // current dom position
    scrollToDomIndex(domIndex + 1); // go to next
  }

  function prevSlide() {
    const domIndex = currentIndex + 1;
    scrollToDomIndex(domIndex - 1);
  }

  function goToSlide(realIndex: number) {
    scrollToDomIndex(realIndex + 1);
  }

  function startAutoplay() {
    stopAutoplay();
    autoplayTimer = setInterval(() => {
      if (!isPaused) nextSlide();
    }, 2000);
  }

  function stopAutoplay() {
    clearInterval(autoplayTimer);
  }

  // Dot click navigation
  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      const index = parseInt((dot as HTMLElement).dataset.index || "0");
      goToSlide(index);
      startAutoplay();
    });
  });

  // Pause on hover
  track.addEventListener("mouseenter", () => { isPaused = true; });
  track.addEventListener("mouseleave", () => { isPaused = false; });

  // Touch/swipe support
  let touchStartX = 0;

  track.addEventListener("touchstart", (e) => {
    touchStartX = e.changedTouches[0].screenX;
    isPaused = true;
  }, { passive: true });

  track.addEventListener("touchend", (e) => {
    const touchEndX = e.changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) {
        nextSlide();
      } else {
        prevSlide();
      }
    }
    isPaused = false;
    startAutoplay();
  }, { passive: true });

  // Initialize — start at real index 0 (domIndex 1), so the last testimonial peeks on the left
  scrollToDomIndex(1, false);
  startAutoplay();

  // Recalculate on resize
  window.addEventListener("resize", () => {
    scrollToDomIndex(currentIndex + 1, false);
  });
</script>

<style>
  .testimonial-track {
    will-change: transform;
    /* Offset so part of the previous card peeks on the left */
    padding-left: max(1.5rem, calc((100vw - 85vw) / 2 - 3rem));
  }

  @media (min-width: 768px) {
    .testimonial-track {
      padding-left: max(3rem, calc((100vw - 560px) / 2 - 4rem));
    }
  }

  @media (min-width: 1024px) {
    .testimonial-track {
      padding-left: max(3rem, calc((100vw - 640px) / 2 - 5rem));
    }
  }
</style>
