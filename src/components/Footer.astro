---
import { Image } from "astro:assets";
import logoCream from "@/assets/images/brand/logo-full-cream.png";

const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: "About", href: "#about" },
  { label: "Volumes", href: "#volumes" },
  { label: "Gallery", href: "#gallery" },
  { label: "Pricing", href: "#pricing" },
  { label: "Join Waitlist", href: "#waitlist" },
  { label: "Log In", href: "https://app.palmnplate.com/login" },
];
---

<footer id="contact" class="bg-charcoal text-cream relative overflow-hidden">
  <!-- Decorative top border -->
  <div class="h-1 bg-gradient-to-r from-clay via-saffron to-olive"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 py-20">
    <div class="grid md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8">

      <!-- Brand column -->
      <div class="lg:col-span-5">
        <Image src={logoCream} alt="Palm & Plate Food Club" width={220} height={90} class="h-20 w-auto mb-6 opacity-80" loading="lazy" />
        <p class="font-body font-light text-cream/40 max-w-sm leading-relaxed mb-8">
          Bahrain's first food club. We bring together food lovers for exclusive dining
          experiences and meaningful connections over great meals.
        </p>

        <!-- Social links -->
        <div class="flex gap-4">
          <a href="https://www.instagram.com/palmnplate/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 border border-cream/10 flex items-center justify-center hover:bg-saffron hover:border-saffron hover:text-charcoal transition-all duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
            </svg>
          </a>
          <a href="#" aria-label="WhatsApp" class="w-10 h-10 border border-cream/10 flex items-center justify-center hover:bg-saffron hover:border-saffron hover:text-charcoal transition-all duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
          </a>
          <a href="#" aria-label="X / Twitter" class="w-10 h-10 border border-cream/10 flex items-center justify-center hover:bg-saffron hover:border-saffron hover:text-charcoal transition-all duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div class="lg:col-span-3">
        <h4 class="font-body font-bold text-xs tracking-widest uppercase text-cream/60 mb-6">Navigate</h4>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="font-body font-light text-cream/40 hover:text-saffron transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="lg:col-span-4">
        <h4 class="font-body font-bold text-xs tracking-widest uppercase text-cream/60 mb-6">Get in Touch</h4>
        <ul class="space-y-4">
          <li>
            <a href="mailto:info@palmnplate.com" class="flex items-center gap-3 font-body font-light text-cream/40 hover:text-saffron transition-colors duration-300 group">
              <svg class="w-4 h-4 text-saffron/60 group-hover:text-saffron transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              info@palmnplate.com
            </a>
          </li>
          <li class="flex items-center gap-3 font-body font-light text-cream/40">
            <svg class="w-4 h-4 text-saffron/60 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Manama, Kingdom of Bahrain
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-cream/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-body text-cream/20 text-xs tracking-wider">
        &copy; {currentYear} Palm & Plate Food Club. All rights reserved.
      </p>
      <p class="font-body text-cream/10 text-xs tracking-wider">
        Made with love in Bahrain
      </p>
    </div>
  </div>
</footer>
