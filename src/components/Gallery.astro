---
import { Image } from "astro:assets";
// Vol 01 — Monsoon (unused elsewhere)
import vol01LaughingImg from "@/assets/images/events/vol01-laughing.jpg";
import vol01DuoImg from "@/assets/images/events/vol01-duo.jpg";
import vol01TableImg from "@/assets/images/events/vol01-table.jpg";
import vol01PortraitImg from "@/assets/images/events/vol01-portrait.jpg";
// Vol 02 — Osteria (unused elsewhere)
import vol02Food2Img from "@/assets/images/events/vol02/vol02-food2.jpg";
// Vol 05 — Diana's Christmas (unused elsewhere)
import vol05FeastImg from "@/assets/images/events/vol05/vol05-feast.jpg";
import vol05MomentImg from "@/assets/images/events/vol05/vol05-moment.jpg";
import vol05OutsideImg from "@/assets/images/events/vol05/vol05-outside.jpg";
// Vol 07 — Rooftop (unused elsewhere)
import vol07SceneImg from "@/assets/images/events/vol07/vol07-scene.jpg";
import vol07LambImg from "@/assets/images/events/vol07/vol07-lamb.jpg";
import vol07Food2Img from "@/assets/images/events/vol07/vol07-food2.jpg";

const images = [
  // Row 1-2: large hero + tall side + 2 singles
  { src: vol01LaughingImg, alt: "Joy at a Vol 01 dinner — Monsoon", span: "col-span-2 row-span-2", w: 800, h: 600 },
  { src: vol07SceneImg, alt: "Members at the Vol 07 rooftop", span: "row-span-2", w: 400, h: 600 },
  { src: vol02Food2Img, alt: "Artichoke dish at Vol 02 — Osteria", span: "", w: 400, h: 300 },
  { src: vol05MomentImg, alt: "Henna hand at the Christmas dinner — Vol 05", span: "", w: 400, h: 300 },
  // Row 3: 4 singles
  { src: vol01DuoImg, alt: "Friends at a Palm & Plate dinner", span: "", w: 400, h: 300 },
  { src: vol07Food2Img, alt: "Hummus and bread at Vol 07", span: "", w: 400, h: 300 },
  { src: vol05FeastImg, alt: "Roast vegetables at Diana's — Vol 05", span: "", w: 400, h: 300 },
  { src: vol01PortraitImg, alt: "Member portrait at Monsoon", span: "", w: 400, h: 300 },
  // Row 4: wide + 2 singles
  { src: vol01TableImg, alt: "Table setting at Monsoon", span: "col-span-2", w: 800, h: 300 },
  { src: vol07LambImg, alt: "Lamb chop at the rooftop dinner — Vol 07", span: "", w: 400, h: 300 },
  { src: vol05OutsideImg, alt: "Members outside Diana's — Vol 05", span: "", w: 400, h: 300 },
];
---

<section id="gallery" class="py-24 md:py-32 bg-charcoal relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <div class="text-center mb-16 reveal">
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="brand-divider"></div>
        <p class="text-saffron font-body font-medium tracking-[0.25em] uppercase text-xs">Gallery</p>
        <div class="brand-divider"></div>
      </div>
      <h2 class="section-heading text-cream mb-6">Moments We've Shared</h2>
      <p class="section-subheading text-cream/40 max-w-xl mx-auto">
        Real people, real food, real connections. A glimpse into our world.
      </p>
    </div>

    <div class="reveal-scale grid grid-cols-2 md:grid-cols-4 auto-rows-[200px] md:auto-rows-[250px] gap-2 md:gap-3">
      {images.map((image) => (
        <div class={`img-zoom rounded-sm ${image.span}`}>
          <Image
            src={image.src}
            alt={image.alt}
            width={image.w}
            height={image.h}
            quality={70}
            format="webp"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      ))}
    </div>

    <div class="text-center mt-12 reveal">
      <a
        href="https://www.instagram.com/palmnplate/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 text-cream/50 hover:text-saffron font-body text-sm tracking-wider transition-colors duration-300 group"
      >
        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
        </svg>
        <span class="tracking-widest uppercase">Follow @palmnplate</span>
      </a>
    </div>

  </div>
</section>
