---
const navLinks = [
  { label: "About", href: "#about" },
  { label: "Events", href: "#events" },
  { label: "Gallery", href: "#gallery" },
  { label: "Membership", href: "#membership" },
  { label: "Contact", href: "#contact" },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <span
          class="text-2xl font-heading font-bold text-white nav-scrolled:text-charcoal transition-colors duration-300"
        >
          Palm & Plate
        </span>
      </a>

      <!-- Desktop Links -->
      <div class="hidden md:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm font-medium text-white/90 hover:text-white nav-scrolled:text-charcoal/70 nav-scrolled:hover:text-palm-600 transition-colors duration-300"
            >
              {link.label}
            </a>
          ))
        }
        <a href="#membership" class="btn-primary text-sm !py-2.5 !px-6">
          Join Us
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden flex flex-col gap-1.5 p-2"
        aria-label="Toggle menu"
      >
        <span
          class="block w-6 h-0.5 bg-white nav-scrolled:bg-charcoal transition-all duration-300 origin-center"
          id="burger-top"></span>
        <span
          class="block w-6 h-0.5 bg-white nav-scrolled:bg-charcoal transition-all duration-300"
          id="burger-mid"></span>
        <span
          class="block w-4 h-0.5 bg-white nav-scrolled:bg-charcoal transition-all duration-300 origin-center"
          id="burger-bot"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 bg-cream z-40 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300"
  >
    <button
      id="mobile-menu-close"
      class="absolute top-6 right-6 p-2"
      aria-label="Close menu"
    >
      <svg
        class="w-7 h-7 text-charcoal"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link text-2xl font-heading font-semibold text-charcoal hover:text-palm-600 transition-colors"
        >
          {link.label}
        </a>
      ))
    }
    <a href="#membership" class="btn-primary mt-4"> Join Us </a>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  const mobileBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileClose = document.getElementById("mobile-menu-close");
  const mobileLinks = document.querySelectorAll(".mobile-nav-link");

  // Scroll effect
  function handleScroll() {
    if (!navbar) return;
    if (window.scrollY > 50) {
      navbar.classList.add("bg-white/95", "backdrop-blur-md", "shadow-sm");
      navbar.classList.add("scrolled");
    } else {
      navbar.classList.remove("bg-white/95", "backdrop-blur-md", "shadow-sm");
      navbar.classList.remove("scrolled");
    }
  }

  window.addEventListener("scroll", handleScroll);
  handleScroll();

  // Mobile menu
  function openMenu() {
    mobileMenu?.classList.remove("opacity-0", "pointer-events-none");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    mobileMenu?.classList.add("opacity-0", "pointer-events-none");
    document.body.style.overflow = "";
  }

  mobileBtn?.addEventListener("click", openMenu);
  mobileClose?.addEventListener("click", closeMenu);
  mobileLinks.forEach((link) => link.addEventListener("click", closeMenu));
</script>

<style>
  /* When nav is scrolled, change child text colors */
  nav.scrolled :global(.nav-scrolled\:text-charcoal) {
    color: theme("colors.charcoal");
  }
  nav.scrolled :global(.nav-scrolled\:text-charcoal\/70) {
    color: rgb(45 45 45 / 0.7);
  }
  nav.scrolled :global(.nav-scrolled\:hover\:text-palm-600:hover) {
    color: theme("colors.palm.600");
  }
  nav.scrolled :global(.nav-scrolled\:bg-charcoal) {
    background-color: theme("colors.charcoal");
  }
</style>
