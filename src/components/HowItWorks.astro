---
import { Image } from "astro:assets";
import logoIconGold from "@/assets/images/brand/logo-icon-gold.png";

const steps = [
  {
    number: "01",
    title: "Join the Waitlist",
    description: "Apply to become a member. Tell us about your love for food and what excites you about dining in Bahrain.",
  },
  {
    number: "02",
    title: "Get Accepted",
    description: "Our team reviews applications to keep the community intimate and like-minded. You'll hear from us soon.",
  },
  {
    number: "03",
    title: "Experience the Table",
    description: "Browse upcoming volumes, reserve your spot, and show up hungry. We handle the rest — from venue to menu.",
  },
];
---

<section class="py-24 md:py-32 bg-charcoal relative overflow-hidden">
  <!-- Subtle background logo -->
  <Image
    src={logoIconGold}
    alt=""
    width={600}
    height={600}
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] opacity-[0.03]"
    loading="lazy"
  />

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <!-- Header -->
    <div class="text-center mb-20 reveal">
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="brand-divider"></div>
        <p class="text-saffron font-body font-medium tracking-[0.25em] uppercase text-xs">How It Works</p>
        <div class="brand-divider"></div>
      </div>

      <h2 class="section-heading text-cream">
        Three Steps to<br />Your Next Great Meal
      </h2>
    </div>

    <!-- Steps -->
    <div class="stagger-children grid md:grid-cols-3 gap-8 lg:gap-16">
      {steps.map((step, i) => (
        <div class="relative text-center md:text-left">
          {/* Connector line on desktop */}
          {i < 2 && (
            <div class="hidden md:block absolute top-8 left-[60%] w-full h-[1px] bg-gradient-to-r from-saffron/40 to-transparent"></div>
          )}

          <div class="relative z-10">
            <span class="text-6xl md:text-7xl font-heading text-saffron/20 leading-none">
              {step.number}
            </span>
            <h3 class="font-heading text-2xl text-cream mt-4 mb-4">{step.title}</h3>
            <p class="font-body font-light text-cream/50 leading-relaxed max-w-sm mx-auto md:mx-0">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
