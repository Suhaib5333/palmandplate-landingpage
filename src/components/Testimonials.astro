---
const testimonials = [
  {
    quote: "Great networking!! Met amazing people and had great bites. 10/10 group and really appreciate the attention to detail!!",
    name: "Jimmy",
  },
  {
    quote: "The experience exceeded what was paid by far.",
    name: "Jonathan",
  },
  {
    quote: "A really great experience so worth it. I am excited to try again in the future!",
    name: "Falah",
  },
  {
    quote: "11/10 no words needed.",
    name: "Ahmed",
  },
  {
    quote: "Absolutely. I'll fly in from Dubai for this if I'm invited again!",
    name: "Sara",
  },
];

// Triple the array for seamless infinite scroll
const tripled = [...testimonials, ...testimonials, ...testimonials];
---

<section class="relative overflow-hidden bg-cream-light py-24 md:py-32">
  <!-- Subtle background accents -->
  <div class="absolute top-0 left-0 w-full h-full pointer-events-none">
    <div class="absolute -top-40 -left-40 w-[500px] h-[500px] bg-saffron/[0.04] rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -right-40 w-[500px] h-[500px] bg-clay/[0.04] rounded-full blur-3xl"></div>
  </div>

  <!-- Top accent line -->
  <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-charcoal/10 to-transparent"></div>

  <!-- Header -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 mb-16 md:mb-20">
    <div class="reveal flex items-center gap-3 mb-6 justify-center">
      <div class="w-12 h-[1px] bg-clay/40"></div>
      <p class="text-clay font-body font-medium tracking-[0.3em] uppercase text-xs">What They Say</p>
      <div class="w-12 h-[1px] bg-clay/40"></div>
    </div>
    <h2 class="reveal section-heading text-charcoal text-center">
      Straight From<br />the Table
    </h2>
  </div>

  <!-- Scrolling testimonials track -->
  <div class="relative z-10 testimonial-wrapper">
    <!-- Gradient fade edges -->
    <div class="absolute left-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-r from-cream-light to-transparent z-20 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-l from-cream-light to-transparent z-20 pointer-events-none"></div>

    <!-- Scrolling track — continuous CSS animation -->
    <div class="testimonial-track flex gap-6 md:gap-8" id="testimonial-track">
      {tripled.map((t, i) => (
        <div class="testimonial-card flex-shrink-0 w-[85vw] md:w-[560px] lg:w-[640px] relative group">
          <div class="h-full border border-charcoal/[0.08] bg-white/60 p-8 md:p-12 transition-colors duration-500 hover:border-clay/20 hover:bg-white/80">
            <!-- Large quote mark -->
            <div class="mb-6 md:mb-8">
              <svg class="w-10 h-10 md:w-14 md:h-14 text-clay/20 group-hover:text-clay/40 transition-colors duration-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
              </svg>
            </div>

            <!-- Quote text -->
            <blockquote class="font-heading text-charcoal text-2xl md:text-3xl lg:text-4xl leading-[1.3] mb-8 md:mb-10" style="line-height: 1.3 !important;">
              {t.quote}
            </blockquote>

            <!-- Author -->
            <div class="flex items-center gap-4">
              <div class="w-10 h-[1px] bg-clay/40"></div>
              <span class="font-body font-medium text-clay tracking-widest uppercase text-sm">
                {t.name}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const track = document.getElementById("testimonial-track") as HTMLElement;
  if (!track) throw new Error("Testimonial track not found");

  const cards = track.querySelectorAll(".testimonial-card");
  const totalOriginal = 5; // number of real testimonials
  const totalCards = cards.length; // 15 (tripled)

  // Calculate one set width for the animation
  function getOneSetWidth(): number {
    const gap = window.innerWidth >= 768 ? 32 : 24;
    let width = 0;
    for (let i = 0; i < totalOriginal; i++) {
      width += (cards[i] as HTMLElement).offsetWidth + gap;
    }
    return width;
  }

  // Set the CSS custom property for animation distance
  function updateAnimationWidth() {
    const oneSetWidth = getOneSetWidth();
    track.style.setProperty("--set-width", `${oneSetWidth}px`);
  }

  // Start from the middle set so there's content on both sides
  function positionTrack() {
    const oneSetWidth = getOneSetWidth();
    // Offset by one full set so the first visible card has content to its left
    track.style.setProperty("--start-offset", `-${oneSetWidth}px`);
  }

  // Pause on hover
  const wrapper = track.parentElement!;
  wrapper.addEventListener("mouseenter", () => {
    track.style.animationPlayState = "paused";
  });
  wrapper.addEventListener("mouseleave", () => {
    track.style.animationPlayState = "running";
  });

  // Pause on touch
  track.addEventListener("touchstart", () => {
    track.style.animationPlayState = "paused";
  }, { passive: true });
  track.addEventListener("touchend", () => {
    track.style.animationPlayState = "running";
  }, { passive: true });

  // Initialize
  updateAnimationWidth();
  positionTrack();

  // Recalculate on resize
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      updateAnimationWidth();
      positionTrack();
    }, 200);
  });
</script>

<style>
  .testimonial-track {
    --set-width: 3400px;
    --start-offset: -3400px;
    --duration: 30s;
    will-change: transform;
    animation: testimonial-scroll var(--duration) linear infinite;
    padding-left: 2rem;
  }

  @keyframes testimonial-scroll {
    0% {
      transform: translateX(var(--start-offset));
    }
    100% {
      transform: translateX(calc(var(--start-offset) - var(--set-width)));
    }
  }

  /* GPU acceleration for buttery smooth scrolling */
  .testimonial-card {
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  .testimonial-wrapper {
    -webkit-overflow-scrolling: touch;
  }

  @media (min-width: 768px) {
    .testimonial-track {
      padding-left: 3rem;
    }
  }
</style>
